{
  "name": "hackz-megalo-back",
  "version": "0.1.0",
  "description": "Receipt Purikura backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cdk:synth": "cd cdk && npx cdk synth",
    "cdk:diff": "cd cdk && npx cdk diff",
    "cdk:deploy": "cd cdk && npx cdk deploy --all --require-approval never"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyiku/hackz-megalo-back.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/kyiku/hackz-megalo-back/issues"
  },
  "homepage": "https://github.com/kyiku/hackz-megalo-back#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.5",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1010.0",
    "@aws-sdk/client-dynamodb": "^3.1010.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/client-sfn": "^3.1010.0",
    "@aws-sdk/lib-dynamodb": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  }
}
